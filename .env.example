# Supabase 프로젝트 설정 (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# 글쓰기 이미지 Storage 버킷 id (기본값 writing_img — 대시보드 Storage 이름과 같게)
# VITE_SUPABASE_STORAGE_WRITING_BUCKET=writing_img

# --- GitHub Pages 배포 (GitHub Actions) ---
# 로컬 개발: 보통 비우거나 VITE_BASE_PATH=/  (기본)
# GitHub Actions 워크플로에서는 저장소 이름으로 자동 설정됩니다. 로컬에서 Pages URL을 미리 보려면:
#   VITE_BASE_PATH=/hanuri_report/
#   npm run build && npm run preview
# 저장소 Settings → Secrets and variables → Actions 에 동일 이름으로:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_GEMINI_API_KEY
# 선택: VITE_GEMINI_MODEL, VITE_SUPABASE_STORAGE_WRITING_BUCKET
# Settings → Pages → Build and deployment 의 Source 를 "GitHub Actions" 로 지정해야 합니다.
# VITE_GEMINI_API_KEY 는 빌드에 포함되므로 공개 배포 시 키 제한(HTTP 리퍼러 등)을 권장합니다.

# --- supabase/migrations 를 SQL Editor 없이 원격 DB에 적용하려면 (Supabase CLI) ---
# 1) npm install (이미 했다면 생략)
# 2) npx supabase login   ← 브라우저로 계정 로그인
# 3) npm run db:link     ← --project-ref 는 대시보드 프로젝트 설정에서 확인
# 4) npm run db:push     ← supabase/migrations 아래 SQL을 순서대로 적용
# 자세한 설명: https://supabase.com/docs/guides/cli/managing-environments

# --- YES24 (로컬 npm run dev + /api/local 만 해당, GitHub Pages에서는 미사용) ---
# 기본은 헤드리스(창 없음). 디버깅할 때만 창 켜기:
# YES24_PLAYWRIGHT_HEADED=1
# YES24_FORCE_HEADLESS=1  ← 이미 기본이 헤드리스라 보통 불필요. 다른 툴이 headed를 켠 경우 강제 헤드리스.

# --- Google Gemini (월간 「이달의 성장 모먼트」 AI 초안) ---
# 브라우저(Vite)에서 호출하므로 변수명은 반드시 VITE_ 로 시작해야 합니다.
# API 키: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
# 사용할 모델 ID (예: gemini-2.0-flash, gemini-2.5-flash-preview-05-20)
VITE_GEMINI_MODEL=gemini-2.0-flash
